{
    "name": "@ujjwalvivek/svg-metro",
    "version": "1.1.0",
    "description": "A playable Mini Metro-inspired transit simulator contained inside one SVG file.",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ujjwalvivek/svgmetro.git"
    },
    "homepage": "https://svgmetro.ujjwalvivek.com",
    "keywords": [
        "svg",
        "game",
        "typescript",
        "mini-metro",
        "simulation",
        "web-audio"
    ],
    "files": [
        "dist"
    ],
    "main": "dist/minimetro.svg",
    "unpkg": "dist/minimetro.svg",
    "jsdelivr": "dist/minimetro.svg",
    "scripts": {
        "prepublishOnly": "npm run build",
        "dev": "node svg-metro.mjs && vite",
        "build": "tsc && node svg-metro.mjs",
        "preview": "vite preview",
        "test": "vitest run",
        "deploy": "npm run build && rm -rf deploy && mkdir -p deploy && cp index.html deploy/index.html && cp dist/minimetro.svg deploy/minimetro.svg && npx wrangler pages deploy deploy/ --project-name=svg-metro"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "vite": "^7.2.7",
        "vitest": "^4.0.16"
    }
}
